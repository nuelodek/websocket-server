# WebSocket Server Configuration

# Environment
NODE_ENV=production
LOG_LEVEL=info

# Server Port
PORT=10000
WS_PORT=10000

# Database Configuration
DB_HOST=your-database-host
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_DATABASE=gegeto_db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Internal API Token (for service-to-service calls)
INTERNAL_API_TOKEN=your-internal-api-token

# API Endpoints
API_BASE_URL=https://api.gegeto.com.ng
VERIFY_STREAM_ACCESS_URL=https://api.gegeto.com.ng/api/verify-stream-access.php

# Redis Configuration (optional, for pub/sub)
REDIS_URL=redis://localhost:6379

# SSL/TLS Configuration (if using self-signed certs)
WS_CERT_PATH=/path/to/ssl/cert.pem
WS_KEY_PATH=/path/to/ssl/key.pem

# Logging
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=5242880
LOG_FILE_MAX_FILES=5
